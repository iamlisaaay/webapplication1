@{
    ViewData["Title"] = "Аналітика продажів";
}

<style>
    body { background-color: #040721; font-family: 'Montserrat', sans-serif; color: white; }
    .chart-card { background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); }
    .custom-select { background-color: #1e293b; color: white; border: 1px solid rgba(255, 255, 255, 0.3); }
    .custom-select:focus { background-color: #0f172a; color: white; border-color: #3b82f6; box-shadow: none; }
    .lost-table-container { max-height: 350px; overflow-y: auto; font-size: 0.8rem; }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="text-white text-uppercase fw-900" style="letter-spacing: 2px;">Аналітика продажів</h1>
        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-light">На головну</a>
    </div>

    <div class="chart-card p-4 rounded-4 mb-4">
        <div class="row align-items-end g-3">
            <div class="col-md-3">
                <label class="text-white-50 small text-uppercase mb-2">Обрати гурт</label>
                <select id="globalGroup" class="form-select custom-select" onchange="updateDashboard()">
                    <option value="0">Всі гурти</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="text-white-50 small text-uppercase mb-2">Період з</label>
                <input type="date" id="dateStart" class="form-control custom-select" onchange="updateDashboard()">
            </div>
            <div class="col-md-3">
                <label class="text-white-50 small text-uppercase mb-2">Період до</label>
                <input type="date" id="dateEnd" class="form-control custom-select" onchange="updateDashboard()">
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-info w-100" onclick="resetDates()">Скинути фільтри</button>
            </div>
        </div>
    </div>

    <div class="chart-card p-4 rounded-4 mb-5">
        <h3 class="mb-4">Динаміка квитків та доходу</h3>
        <div id="salesChart" style="height: 400px; width: 100%;"></div>
    </div>

    <div class="chart-card p-4 rounded-4 mb-5">
        <h3 class="mb-4 text-center">Аналіз прибутковості</h3>
        <div class="row g-4">
            <div class="col-lg-5">
                <div id="lostChart" style="height: 350px; width: 100%;"></div>
            </div>
            <div class="col-lg-4 text-center">
                <h5 class="text-white-50 small text-uppercase">Відсоткове співвідношення</h5>
                <div id="pieChart" style="height: 350px; width: 100%;"></div>
            </div>
            <div class="col-lg-3">
                <h5 class="text-white-50 small text-uppercase mb-3">Деталі по місяцях</h5>
                <div class="lost-table-container rounded border border-secondary">
                    <table class="table table-dark table-sm m-0">
                        <thead class="sticky-top bg-dark">
                            <tr><th>Місяць</th><th class="text-success">Дохід</th><th class="text-danger">Втрати</th></tr>
                        </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://www.gstatic.com/charts/loader.js"></script>
    <script>
        google.charts.load('current', { 'packages': ['corechart'] });
        google.charts.setOnLoadCallback(init);

        function init() {
            fetch('/api/charts/groups').then(r => r.json()).then(data => {
                const s = document.getElementById('globalGroup');
                data.forEach(g => {
                    const o = document.createElement('option');
                    o.value = g.id; o.textContent = g.name;
                    s.appendChild(o);
                });
                updateDashboard();
            });
        }

        function resetDates() {
            document.getElementById('dateStart').value = '';
            document.getElementById('dateEnd').value = '';
            document.getElementById('globalGroup').value = '0';
            updateDashboard();
        }

        function updateDashboard() {
            const gid = document.getElementById('globalGroup').value;
            const s = document.getElementById('dateStart').value;
            const e = document.getElementById('dateEnd').value;
            const params = `?groupId=${gid}&startDate=${s}&endDate=${e}`;

            drawSales(params);
            drawProfit(params);
        }

        function drawSales(p) {
            fetch('/api/charts/monthlySales' + p).then(r => r.json()).then(data => {
                const dt = new google.visualization.DataTable();
                dt.addColumn('string', 'Місяць');
                dt.addColumn('number', 'Квитки');
                dt.addColumn('number', 'Гроші');
                data.forEach(d => dt.addRow([d.monthLabel, d.ticketsSold, d.revenue]));

                new google.visualization.ComboChart(document.getElementById('salesChart')).draw(dt, {
                    backgroundColor: 'transparent',
                    colors: ['#3b82f6', '#10b981'],
                    seriesType: 'bars',
                    series: { 1: { type: 'line', targetAxisIndex: 1, lineWidth: 4, pointSize: 8 } },
                    legend: { textStyle: { color: '#fff' }, position: 'top' },
                    hAxis: { textStyle: { color: '#fff' }, gridlines: { color: 'transparent' } },
                    vAxes: {
                        0: { title: 'Квитки', textStyle: { color: '#fff' }, gridlines: { color: 'rgba(255,255,255,0.1)' } },
                        1: { title: 'Гроші (₴)', textStyle: { color: '#fff' }, format: '#,### ₴' }
                    },
                    chartArea: { width: '85%', height: '75%' }
                });
            });
        }

        function drawProfit(p) {
            fetch('/api/charts/lostRevenue' + p).then(r => r.json()).then(data => {
                const dt = new google.visualization.DataTable();
                dt.addColumn('string', 'Місяць');
                dt.addColumn('number', 'Зароблено');
                dt.addColumn('number', 'Втрачено');

                let totalE = 0, totalL = 0;
                const body = document.getElementById('tableBody');
                body.innerHTML = '';

                data.forEach(d => {
                    dt.addRow([d.monthLabel, d.earnedRevenue, d.lostRevenue]);
                    totalE += d.earnedRevenue; totalL += d.lostRevenue;
                    body.innerHTML += `<tr><td>${d.monthLabel}</td><td class="text-success">${d.earnedRevenue.toLocaleString()}</td><td class="text-danger">${d.lostRevenue.toLocaleString()}</td></tr>`;
                });

                // Стовпчиковий графік
                new google.visualization.ColumnChart(document.getElementById('lostChart')).draw(dt, {
                    backgroundColor: 'transparent', colors: ['#10b981', '#ef4444'],
                    legend: { textStyle: { color: '#fff' }, position: 'top' },
                    hAxis: { textStyle: { color: '#fff' } },
                    vAxis: { textStyle: { color: '#fff' }, format: '#,### ₴', gridlines: { color: 'rgba(255,255,255,0.1)' } },
                    chartArea: { width: '80%', height: '75%' }
                });

                // Кругова діаграма
                const pieDt = google.visualization.arrayToDataTable([
                    ['Статус', 'Сума'],
                    ['Зароблено', totalE],
                    ['Втрачено', totalL]
                ]);

                new google.visualization.PieChart(document.getElementById('pieChart')).draw(pieDt, {
                    backgroundColor: 'transparent', colors: ['#10b981', '#ef4444'],
                    legend: { textStyle: { color: '#fff' }, position: 'bottom' },
                    pieHole: 0.4,
                    pieSliceTextStyle: { color: 'black', fontSize: 12, fontWeight: 'bold' },
                    chartArea: { width: '100%', height: '80%' }
                });
            });
        }
    </script>
}