@{
    ViewData["Title"] = "Аналітика продажів";
}

<style>
    body {
        background-color: #040721;
        font-family: 'Montserrat', sans-serif;
    }

    .chart-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
    }

    .custom-select {
        background-color: #1e293b;
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

        .custom-select:focus {
            background-color: #0f172a;
            color: white;
            border-color: #3b82f6;
            box-shadow: none;
        }

    .lost-table-container {
        max-height: 400px;
        overflow-y: auto;
    }

    .lost-table {
        color: white;
        background: rgba(255, 255, 255, 0.05);
        font-size: 0.85rem;
    }

        .lost-table thead th {
            position: sticky;
            top: 0;
            background: #1e293b;
            z-index: 1;
        }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white text-uppercase" style="font-weight: 900; letter-spacing: 2px;">Аналітика продажів</h1>
        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-light">Повернутися на головну</a>
    </div>

    <div class="p-4 rounded-4 shadow chart-card mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-white m-0">Динаміка активності по місяцях</h3>
            <div style="width: 250px;">
                <select id="groupSelectorSales" class="form-select custom-select" onchange="loadMonthlySalesChart()">
                    <option value="0">Всі гурти</option>
                </select>
            </div>
        </div>
        <div id="monthlySalesChart" style="height: 400px; width: 100%;"></div>
    </div>

    <div class="p-4 rounded-4 shadow chart-card mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-white m-0">Порівняння прибутку та втрат</h3>
            <div style="width: 250px;">
                <select id="groupSelectorLost" class="form-select custom-select" onchange="loadLostRevenueChart()">
                    <option value="0">Всі гурти</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div id="lostRevenueChart" style="height: 400px; width: 100%;"></div>
            </div>
            <div class="col-lg-4">
                <h5 class="text-white-50 mb-3">Зведена таблиця</h5>
                <div class="lost-table-container rounded border border-secondary">
                    <table class="table table-dark table-hover table-sm lost-table">
                        <thead>
                            <tr>
                                <th>Місяць</th>
                                <th class="text-success">Дохід</th>
                                <th class="text-danger">Втрати</th>
                            </tr>
                        </thead>
                        <tbody id="comparisonTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', { 'packages': ['corechart'] });
        google.charts.setOnLoadCallback(initDashboard);

        function initDashboard() {
        loadGroups();
        loadMonthlySalesChart();
        loadLostRevenueChart();
        }

        function loadGroups() {
        fetch('/api/charts/groups')
        .then(r => r.json())
        .then(data => {
        const s1 = document.getElementById('groupSelectorSales');
        const s2 = document.getElementById('groupSelectorLost');
        data.forEach(g => {
        const opt = document.createElement('option');
        opt.value = g.id;
        opt.textContent = g.name;
        s1.appendChild(opt.cloneNode(true));
        s2.appendChild(opt);
        });
        });
        }

        function loadMonthlySalesChart() {
        const gid = document.getElementById('groupSelectorSales').value;
        const url = gid > 0 ? `/api/charts/monthlySales?groupId=${gid}` : '/api/charts/monthlySales';

        fetch(url).then(r => r.json()).then(data => {
        const dt = new google.visualization.DataTable();
        dt.addColumn('string', 'Місяць');
        dt.addColumn('number', 'Квитки');
        dt.addColumn('number', 'Заробіток');
        data.forEach(i => dt.addRow([i.monthLabel, i.ticketsSold, i.revenue]));

        new google.visualization.ComboChart(document.getElementById('monthlySalesChart')).draw(dt, {
        backgroundColor: 'transparent',
        colors: ['#3b82f6', '#10b981'],
        seriesType: 'bars',
        series: { 1: { type: 'line', targetAxisIndex: 1, lineWidth: 4, pointSize: 10 } },
        legend: { textStyle: { color: '#fff' }, position: 'top' },
        hAxis: { textStyle: { color: '#fff' } },
        vAxes: {
        0: { title: 'Квитки', textStyle: { color: '#fff' }, gridlines: { count: 6, color: 'rgba(255,255,255,0.1)' }, viewWindow: {min:0} },
        1: { title: 'Гроші (₴)', textStyle: { color: '#fff' }, gridlines: { count: 6, color: 'transparent' }, format: '#,### ₴', viewWindow: {min:0} }
        },
        chartArea: { width: '80%', height: '70%' }
        });
        });
        }

        function loadLostRevenueChart() {
        const gid = document.getElementById('groupSelectorLost').value;
        const url = gid > 0 ? `/api/charts/lostRevenue?groupId=${gid}` : '/api/charts/lostRevenue';

        fetch(url).then(r => r.json()).then(data => {
        const dt = new google.visualization.DataTable();
        dt.addColumn('string', 'Місяць');
        dt.addColumn('number', 'Зароблено');
        dt.addColumn('number', 'Втрачено');

        const tbody = document.getElementById('comparisonTableBody');
        tbody.innerHTML = '';

        data.forEach(i => {
        dt.addRow([i.monthLabel, i.earnedRevenue, i.lostRevenue]);
        tbody.innerHTML += `
        <tr>
        <td>${i.monthLabel}</td>
        <td class="text-success">${i.earnedRevenue.toLocaleString()} ₴</td>
        <td class="text-danger">${i.lostRevenue.toLocaleString()} ₴</td>
        </tr>`;
        });

        new google.visualization.ColumnChart(document.getElementById('lostRevenueChart')).draw(dt, {
        backgroundColor: 'transparent',
        colors: ['#10b981', '#ef4444'],
        legend: { textStyle: { color: '#fff' }, position: 'top' },
        hAxis: { textStyle: { color: '#fff' } },
        vAxis: {
        textStyle: { color: '#fff' },
        gridlines: { count: 6, color: 'rgba(255,255,255,0.1)' },
        format: '#,### ₴',
        viewWindow: {min:0}
        },
        chartArea: { width: '85%', height: '70%' }
        });
        });
        }
    </script>
}