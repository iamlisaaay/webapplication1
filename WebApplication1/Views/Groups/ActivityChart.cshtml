@{
    ViewData["Title"] = "Активність гуртів";
}

<style>
    body {
        background-color: #040721; /* Твій фірмовий темний фон */
        font-family: 'Montserrat', sans-serif;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white text-uppercase" style="font-weight: 900; letter-spacing: 2px;">Активність гуртів</h1>
        <a asp-action="Index" class="btn btn-outline-light">Повернутися до списку</a>
    </div>

    <div class="p-4 rounded-4 shadow" style="background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px);">
        <div id="groupActivityChart" style="height: 500px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});
        google.charts.setOnLoadCallback(drawChart);

        function drawChart() {
        fetch('/api/charts/groupActivity')
        .then(response => response.json())
        .then(data => {
        const dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Гурт');
        dataTable.addColumn('number', 'Кількість концертів');

        data.forEach(item => {
        // Тут важливо, щоб імена змінних збігалися з тими, що в контролері
        dataTable.addRow([item.groupName, item.concertCount]);
        });

        const options = {
        backgroundColor: 'transparent',
        pieHole: 0.4,
        colors: ['#ef4444', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899', '#3b82f6'],
        legend: { position: 'right', textStyle: { color: 'white', fontSize: 14, fontName: 'Montserrat' } },
        chartArea: { width: '90%', height: '90%' }
        };

        const chart = new google.visualization.PieChart(document.getElementById('groupActivityChart'));
        chart.draw(dataTable, options);
        })
        .catch(error => console.error('Помилка завантаження даних:', error));
        }
    </script>
}