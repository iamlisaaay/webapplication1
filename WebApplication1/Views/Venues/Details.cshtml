@model Concert.Models.Venue

@{
    ViewData["Title"] = Model.Name;
}

<style>
    /* Фірмові стилі для скляної картки локації */
    .venue-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
        overflow: hidden;
    }

    .page-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 5px;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
    }

    /* Красиві бокси для характеристик залу */
    .stat-box {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1rem;
        padding: 1.5rem 1rem;
        text-align: center;
        transition: 0.3s;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
        .stat-box:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(96, 165, 250, 0.5);
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

    .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,0.5);
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #60a5fa; /* Світло-синій акцент */
    }
</style>

<div class="container py-5 mt-4">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-light btn-sm text-uppercase" style="letter-spacing: 1px;">
            ← До списку локацій
        </a>
    </div>

    <div class="venue-card p-0">
        <div class="row g-0 align-items-stretch">
            
            <div class="col-lg-5">
                <img src="@Url.Content(!string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/images/default-venue.jpg")"
                     alt="@Model.Name"
                     style="width: 100%; height: 100%; min-height: 400px; object-fit: cover;"
                     onerror="this.src='/images/default-venue.jpg';">
            </div>

            <div class="col-lg-7 p-5 d-flex flex-column justify-content-center">
                
                <h1 class="page-title mb-2">@Model.Name</h1>
                
                <p class="text-white-50 fs-5 mb-5">
                    📍 @(string.IsNullOrEmpty(Model.Address) ? "Адреса не вказана" : Model.Address)
                </p>

                <div class="row g-3 mb-5">
                    <div class="col-sm-4">
                        <div class="stat-box">
                            <div class="stat-label">Місткість</div>
                            <div class="stat-value">@(Model.Capacity?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-box">
                            <div class="stat-label">Всього рядів</div>
                            <div class="stat-value">@(Model.TotalRows?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="stat-box">
                            <div class="stat-label">Загалом місць</div>
                            <div class="stat-value">@(Model.TotalSeats?.ToString() ?? "—")</div>
                        </div>
                    </div>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="mt-auto d-flex gap-3 border-top border-secondary border-opacity-25 pt-4">
                        <a asp-action="Edit" asp-route-id="@Model?.VenueId" class="btn btn-outline-warning text-uppercase px-4 py-2" style="letter-spacing: 1px; font-size: 0.85rem;">
                            ✏️ Редагувати
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model?.VenueId" class="btn btn-outline-danger text-uppercase px-4 py-2" style="letter-spacing: 1px; font-size: 0.85rem;">
                            🗑️ Видалити
                        </a>
                    </div>
                }
            </div>
            
        </div>
    </div>
</div>