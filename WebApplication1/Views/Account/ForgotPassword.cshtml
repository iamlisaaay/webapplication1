@model Concert.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<style>
    .auth-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
    }
    .custom-input {
        background-color: rgba(0, 0, 0, 0.2) !important;
        color: white !important;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .custom-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
    }
    .custom-label {
        color: rgba(255, 255, 255, 0.6);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }
    .page-title {
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
    }
</style>

<div class="row justify-content-center mt-5 py-5">
    <div class="col-md-5 col-lg-4">
        <h2 class="text-center mb-4 page-title text-white">Відновлення пароля</h2>
        <div class="auth-card p-4 p-md-5">
            <form asp-action="ForgotPassword" method="post">
                <div class="form-group mb-4">
                    <label asp-for="Email" class="control-label custom-label"></label>
                    <input asp-for="Email" class="form-control custom-input" placeholder="Введіть вашу пошту" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-outline-primary w-100 text-uppercase" style="letter-spacing: 1px; font-weight: 600;">Відправити лист</button>
            </form>
        </div>
    </div>
</div>