@{
    ViewData["Title"] = "Прибутковість концертів";
}

<style>
    body {
        background-color: #040721;
        font-family: 'Montserrat', sans-serif;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-white text-uppercase" style="font-weight: 900; letter-spacing: 2px;">Прибутковість концертів</h1>
        <a asp-action="Index" class="btn btn-outline-light">Повернутися до списку</a>
    </div>

    <div class="p-4 rounded-4 shadow" style="background: rgba(30, 41, 59, 0.6); border: 1px solid rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px);">
        <div id="revenueChart" style="height: 500px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});
        google.charts.setOnLoadCallback(drawChart);

        function drawChart() {
        fetch('/api/charts/revenueByConcert')
        .then(response => response.json())
        .then(data => {
        const dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Концерт');
        dataTable.addColumn('number', 'Прибуток (₴)');

        data.forEach(item => {
        dataTable.addRow([item.concertTitle, item.totalRevenue]);
        });

        const options = {
        backgroundColor: 'transparent',
        legend: { position: 'none' },
        colors: ['#d4a373'],
        hAxis: {
        textStyle: { color: 'rgba(255,255,255,0.7)', fontName: 'Montserrat' },
        gridlines: { color: 'transparent' }
        },
        vAxis: {
        textStyle: { color: 'rgba(255,255,255,0.7)', fontName: 'Montserrat' },
        gridlines: { color: 'rgba(255,255,255,0.1)' }
        },
        chartArea: { width: '85%', height: '80%' }
        };

        const chart = new google.visualization.ColumnChart(document.getElementById('revenueChart'));
        chart.draw(dataTable, options);
        })
        .catch(error => console.error('Помилка завантаження даних:', error));
        }
    </script>
}