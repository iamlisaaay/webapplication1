@model Concert.Models.Concert

@{
    ViewData["Title"] = "Скасування події";
}

<style>
    body {
        background-color: #040721;
        color: white;
        font-family: 'Montserrat', sans-serif;
    }

    .delete-container {
        max-width: 700px;
        margin: 80px auto;
        padding: 40px;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(239, 68, 68, 0.4);
        border-radius: 1.5rem;
        text-align: center;
    }

    .concert-preview {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: 1rem;
        margin-bottom: 25px;
        opacity: 0.7;
    }
</style>

<div class="container">
    <div class="delete-container">
        <h1 class="text-danger fw-black text-uppercase mb-4" style="letter-spacing: 5px;">Скасувати подію?</h1>

        <img src="@Url.Content(!string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/images/default-concert.jpg")"
             class="concert-preview" alt="Poster">

        <h2 class="fw-bold mb-1">@Model.Title</h2>
        <p class="text-info mb-5">📅 @Model.DateTime?.ToString("dd.MM.yyyy HH:mm")</p>

        <form asp-action="Delete">
            <input type="hidden" asp-for="ConcertId" />
            <div class="d-flex gap-3 justify-content-center">
                <a asp-action="Index" class="btn btn-outline-light px-5" style="border-radius: 50px;">Назад</a>
                <button type="submit" class="btn btn-danger px-5" style="border-radius: 50px; background-color: #ef4444;">Видалити назавжди</button>
            </div>
        </form>
    </div>
</div>