@model Concert.Models.Concert

@{
    ViewData["Title"] = Model.Title;

    // ЛОГІКА ДЛЯ БЕЙДЖА СТАТУСУ
    string statusText = "Невідомо";
    string statusClass = "badge-past";
    string statusIcon = "⚪";

    if (Model.DateTime.HasValue)
    {
        var concertDate = Model.DateTime.Value.Date;
        var today = DateTime.UtcNow.Date;

        if (concertDate > today)
        {
            statusText = "Скоро";
            statusClass = "badge-upcoming";
            statusIcon = "🟢";
        }
        else if (concertDate == today)
        {
            statusText = "Сьогодні";
            statusClass = "badge-today";
            statusIcon = "🔴";
        }
        else
        {
            statusText = "Минув";
            statusClass = "badge-past";
            statusIcon = "⚪";
        }
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap');

    body {
        background-color: #040721;
        color: white;
        font-family: 'Montserrat', sans-serif;
    }

    .page-title {
        font-size: clamp(2rem, 5vw, 4rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 5px;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
    }
    /* Еффект світіння для посилань */
    .hover-glow {
        transition: 0.3s;
    }
    .hover-glow:hover {
        color: #60a5fa !important;
        text-shadow: 0 0 8px rgba(96, 165, 250, 0.6);
    }

    /* === БЕЙДЖІ СТАТУСУ === */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .badge-upcoming {
        background: rgba(34, 197, 94, 0.2);
        color: #4ade80;
        border-color: rgba(74, 222, 128, 0.3);
    }

    .badge-today {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
        border-color: rgba(248, 113, 113, 0.3);
        animation: pulse 2s infinite;
    }

    .badge-past {
        background: rgba(148, 163, 184, 0.2);
        color: #cbd5e1;
        border-color: rgba(203, 213, 225, 0.3);
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(239, 68, 68, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
        }
    }

    /* === СТИЛІ 3D-КАРТОК === */
    .holographic-card {
        perspective: 1000px;
        height: 100%;
    }

    .holographic-card__inner {
        will-change: transform;
        transition: transform 0.1s ease-out, box-shadow 0.3s ease;
        transform-style: preserve-3d;
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
    }

    .holographic-card:hover .holographic-card__inner {
        box-shadow: 0 15px 35px rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
    }

    /* === ВЕНЮ (МІСЦЕ) === */
    .venue-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .venue-img {
        width: 150px;
        height: 150px;
        object-fit: cover;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 15px;
    }
</style>

<div class="container py-5 mt-4">

    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-light btn-sm text-uppercase" style="letter-spacing: 1px;">
            ← До списку
        </a>
    </div>

    <div class="row mb-5 align-items-center">

        <div class="col-lg-5 mb-4 mb-lg-0">
            <div class="holographic-card">
                <div class="holographic-card__inner" style="border-radius: 2rem;">
                    <img src="@Url.Content(!string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "/images/default-concert.jpg")"
                         alt="@Model.Title"
                         style="width: 100%; aspect-ratio: 3/4; object-fit: cover;"
                         onerror="this.src='/images/default-concert.jpg';">
                </div>
            </div>
        </div>

        <div class="col-lg-7 ps-lg-5">
            <div class="mb-4">
                <span class="status-badge @statusClass">
                    @statusIcon @statusText
                </span>
            </div>

            <h1 class="page-title mb-4">@Model.Title</h1>

            <div class="mb-5">
                <h4 class="text-white-50 text-uppercase" style="letter-spacing: 2px; font-weight: 300; font-size: 1rem;">Дата та час</h4>
                <p class="fs-4 fw-bold mb-0">@Model.DateTime?.ToString("dd.MM.yyyy")</p>
                <p class="fs-5 text-info mb-0">@Model.DateTime?.ToString("HH:mm")</p>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <div class="d-flex gap-3">
                    <a asp-action="Edit" asp-route-id="@Model?.ConcertId" class="btn btn-outline-light text-uppercase px-4 py-2" style="letter-spacing: 2px;">Редагувати</a>
                </div>            
            }
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h3 class="section-title">Місце проведення</h3>

            <div class="venue-card">
                <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId">
                    <img src="@Url.Content(!string.IsNullOrEmpty(Model.Venue?.ImageUrl) ? Model.Venue.ImageUrl : "/images/default-venue.jpg")"
                         alt="@Model.Venue?.Name"
                         class="venue-img"
                         onerror="this.src='/images/default-venue.jpg';">
                </a>

                <div class="p-4">
                    <h4 class="fw-bold text-uppercase mb-1" style="letter-spacing: 2px;">
                        <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId" class="text-white text-decoration-none hover-glow">
                            @Model.Venue?.Name
                        </a>
                    </h4>
                    @if (!string.IsNullOrEmpty(Model.Venue?.Address))
                    {
                        <p class="text-white-50 mb-0">📍 @Model.Venue.Address</p>
                    }
                    
                    <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId" class="btn btn-sm btn-outline-info mt-3 text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">
                        Детальніше про локацію
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <h3 class="section-title">Лайнап</h3>
        </div>

        @if (Model.Groups != null && Model.Groups.Any())
        {
            @foreach (var group in Model.Groups)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="holographic-card">
                        <div class="holographic-card__inner h-100">
                            <div style="height: 200px; overflow: hidden; position: relative;">
                                <img src="@Url.Content(!string.IsNullOrEmpty(group.VideoUrl) ? group.VideoUrl : "/images/default-group.jpg")"
                                     alt="@group.Name"
                                     style="width: 100%; height: 100%; object-fit: cover;"
                                     onerror="this.src='/images/default-group.jpg';">
                            </div>
                            <div class="card-body p-3 text-center">
                                <h5 class="fw-bold mb-0 text-uppercase" style="letter-spacing: 2px; font-size: 1rem;">
                                    @group.Name
                                </h5>
                            </div>
                            <div class="p-3 pt-0 mt-auto">
                                <a asp-controller="Groups" asp-action="Details" asp-route-id="@group.GroupId" class="btn btn-sm btn-outline-light w-100 text-uppercase opacity-75" style="letter-spacing: 1px; font-size: 0.7rem;">Сторінка гурту</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-white-50 fst-italic fs-5">Гурти ще не додані до цього концерту.</p>
            </div>
        }
    </div>
    <div class="mb-5 p-4 rounded-4" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1);">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <form asp-controller="Comments" asp-action="Create" method="post">
                <input type="hidden" name="concertId" value="@Model.ConcertId" />
                <div class="mb-3">
                    <label for="commentText" class="form-label text-white-50 text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem;">Залиште свій відгук</label>
                    <textarea id="commentText" name="text" class="form-control text-white border-secondary shadow-none" rows="3" placeholder="Як вам концерт?..." required style="background: rgba(0,0,0,0.3);"></textarea>
                </div>
                <div class="text-end">
                    <button type="submit" class="btn btn-outline-info text-uppercase px-4" style="letter-spacing: 2px; font-weight: 700;">
                        Відправити
                    </button>
                </div>
            </form>
        }
        else
        {
            <div class="text-center py-3">
                <p class="text-white-50 mb-2">Щоб залишити коментар, потрібно увійти в систему.</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm text-uppercase" style="letter-spacing: 1px;">Увійти</a>
            </div>
        }
    </div>
   <div class="comments-list">
    @if (Model.Comments != null && Model.Comments.Any())
    {
        // Отримуємо ID поточного користувача для перевірки прав
        var currentUserId = User.FindFirst("UserId")?.Value;
        var isAdmin = User.IsInRole("Admin");

        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
        {
            <div class="card mb-3 border-0 rounded-4 shadow-sm" style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(5px);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-center border-bottom border-secondary mb-3 pb-2">
                        
                        <div class="d-flex align-items-center gap-3">
                            <img src="@(!string.IsNullOrEmpty(comment.Customer?.AvatarUrl) ? comment.Customer.AvatarUrl : "/images/default-avatar.png")"
                                 alt="Avatar"
                                 class="rounded-circle object-fit-cover"
                                 style="width: 45px; height: 45px; border: 2px solid rgba(96, 165, 250, 0.5);"
                                 onerror="this.src='/images/default-avatar.png';">
                            <h6 class="mb-0 fw-bold text-info" style="letter-spacing: 1px;">
                                @(comment.Customer?.FullName ?? "Невідомий користувач")
                            </h6>
                        </div>

                        <small class="text-white-50" style="font-size: 0.8rem;">
                            @comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </small>
                    </div>

                    <p id="comment-text-@comment.CommentId" class="card-text mb-0" style="line-height: 1.6; font-weight: 300;">
                        @comment.Text
                    </p>

                    <form id="edit-form-@comment.CommentId" asp-controller="Comments" asp-action="Edit" method="post" class="d-none mt-3">
                        <input type="hidden" name="commentId" value="@comment.CommentId" />
                        <input type="hidden" name="concertId" value="@Model.ConcertId" />
                        <textarea name="newText" class="form-control text-white mb-2" style="background: rgba(0,0,0,0.5); border: 1px solid #60a5fa;" rows="2">@comment.Text</textarea>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-sm btn-success px-3">Зберегти</button>
                            <button type="button" class="btn btn-sm btn-outline-light px-3" onclick="toggleEdit(@comment.CommentId)">Скасувати</button>
                        </div>
                    </form>

                    @if (currentUserId == comment.CustomerId.ToString() || isAdmin)
                    {
                        <div class="d-flex justify-content-end gap-3 mt-3 pt-2" style="border-top: 1px dashed rgba(255,255,255,0.1);">
                            
                            @if (currentUserId == comment.CustomerId.ToString())
                            {
                                <button type="button" class="btn btn-sm text-info p-0 text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem; background: none; border: none;" onclick="toggleEdit(@comment.CommentId)">
                                    ✏️ Редагувати
                                </button>
                            }

                            <form asp-controller="Comments" asp-action="Delete" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цей коментар?');" class="m-0 p-0">
                                <input type="hidden" name="commentId" value="@comment.CommentId" />
                                <input type="hidden" name="concertId" value="@Model.ConcertId" />
                                <button type="submit" class="btn btn-sm text-danger p-0 text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem; background: none; border: none;">
                                    🗑 Видалити
                                </button>
                            </form>
                        </div>
                    }

                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4">
            <p class="text-white-50 fst-italic fs-5 mb-0">Ще немає коментарів. Ваш буде першим!</p>
        </div>
    }
</div>

</div>

@section Scripts {
    <script>
        // Функція для перемикання форми редагування
        function toggleEdit(commentId) {
            var textElement = document.getElementById('comment-text-' + commentId);
            var formElement = document.getElementById('edit-form-' + commentId);
            
            if (formElement.classList.contains('d-none')) {
                formElement.classList.remove('d-none');
                textElement.classList.add('d-none');
            } else {
                formElement.classList.add('d-none');
                textElement.classList.remove('d-none');
            }
        }

        // Твій існуючий код для 3D карток
        document.querySelectorAll('.holographic-card').forEach(card => {
            const inner = card.querySelector('.holographic-card__inner');

            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                const px = (x / rect.width) * 100;
                const py = (y / rect.height) * 100;

                const tiltX = (py - 50) / 3;
                const tiltY = (50 - px) / 3;

                inner.style.transform = `rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
            });

            card.addEventListener('mouseleave', () => {
                inner.style.transform = `rotateX(0deg) rotateY(0deg)`;
            });
        });
    </script>
}