@model IEnumerable<Concert.Models.Concert>

@{
    ViewData["Title"] = "Головна";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap');

    body {
        background-color: #040721;
        color: white;
        font-family: 'Montserrat', sans-serif;
    }

    /* === СТИЛЬ ЗАГОЛОВКА === */
    .page-title {
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 5px;
        text-shadow: 0 0 20px rgba(255,255,255,0.2);
    }

    .navbar {
        background-color: #040721 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.9);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
        position: relative;
        z-index: 1000;
    }
    #liveSearch::placeholder {
    color: rgba(255, 255, 255, 0.85);
    opacity: 1;
    font-weight: 400;
}

#liveSearch:focus::placeholder {
    color: rgba(255, 255, 255, 0.5);
}

    .navbar-brand, .nav-link {
        color: #ffffff !important;
        transition: color 0.3s ease;
    }

        .nav-link:hover {
            color: #3b82f6 !important;
        }

    /* === СТИЛІ 3D-КАРТОК === */
    .holographic-card {
        perspective: 1000px;
        height: 100%;
    }

    .holographic-card__inner {
        will-change: transform;
        transition: transform 0.1s ease-out, box-shadow 0.3s ease;
        transform-style: preserve-3d;
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 1.5rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
    }

    .holographic-card:hover .holographic-card__inner {
        box-shadow: 0 15px 35px rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
    }

    .card-title {
        color: #f8fafc !important;
        font-size: 1.25rem;
    }

    .text-muted {
        color: #94a3b8 !important;
    }

    .card-content {
        pointer-events: none;
    }
</style>

<div class="container py-5 mt-4">

    <div class="text-center mb-5">
        <h1 class="page-title">Найближчі події</h1>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-5">
                <div class="holographic-card">
                    <div class="holographic-card__inner h-100">

                        <div style="height: 250px; overflow: hidden; position: relative; flex-shrink: 0;">
                            <img src="@Url.Content(item.ImageUrl ?? "/images/default-concert.jpg")"
                                 class="w-full h-full"
                                 alt="Poster"
                                 style="width: 100%; height: 100%; object-fit: cover;"
                                 onerror="this.src='/images/default-concert.jpg';">
                        </div>

                        <div class="card-body p-4 card-content flex-grow-1">
                            <h5 class="card-title fw-bold mb-2 text-uppercase" style="letter-spacing: 2px;">@item.Title</h5>
                            <p class="mb-1 text-muted">
                                📅 @item.DateTime?.ToString("dd.MM.yyyy HH:mm")
                            </p>
                            <p class="mb-0 text-muted">
                                📍 <strong>@item.Venue?.Name</strong>
                            </p>
                        </div>

                        <div class="p-4 pt-0 mt-auto">
                            <div class="d-grid gap-2">
                                <a asp-controller="Concerts" asp-action="Details" asp-route-id="@item.ConcertId"
                                   class="btn btn-outline-light btn-sm py-2 text-uppercase" style="letter-spacing: 1px;">
                                    Детальніше
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {

}